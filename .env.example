# Firebase — chaves "web" do app (públicas; a segurança vem das Security Rules).
# Copie este arquivo para `.env` e cole os valores do console do Firebase:
#   Console → ⚙️ Configurações do projeto → Seus apps → Web → SDK setup and configuration → Config
# Reinicie o `expo start` após criar/editar o `.env`.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Gemini API Key
EXPO_PUBLIC_GEMINI_API_KEY=
